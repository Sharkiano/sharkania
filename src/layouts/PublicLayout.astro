</style>

<script>
  // ── Search dropdown toggle ──────────────────
  const searchBtn   = document.getElementById('nav-search-btn');
  const searchDrop  = document.getElementById('nav-search-dropdown');
  const searchInput = document.getElementById('nav-search-input');

  searchBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = searchDrop?.classList.toggle('open');
    searchBtn.classList.toggle('active', isOpen ?? false);
    if (isOpen) setTimeout(() => searchInput?.focus(), 50);
  });

  document.addEventListener('click', (e) => {
    const wrap = document.getElementById('nav-search-wrap');
    if (wrap && !wrap.contains(e.target as Node)) {
      searchDrop?.classList.remove('open');
      searchBtn?.classList.remove('active');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchDrop?.classList.remove('open');
      searchBtn?.classList.remove('active');
    }
  });

const toggle = document.getElementById('nav-toggle');
const menu   = document.getElementById('nav-mobile');

toggle?.addEventListener('click', () => {
  menu?.classList.toggle('is-open');
});

function closeMobileMenu() {
  menu?.classList.remove('is-open');
}

(window as any).closeMobileMenu = closeMobileMenu;
</script>