---
// src/pages/buscar.astro
import PublicLayout from '@layouts/PublicLayout.astro';
import { createServerClient } from '@lib/supabase/server';

const q        = Astro.url.searchParams.get('q') ?? '';
const supabase = createServerClient();
const hasQuery = q.trim().length >= 2;

let players:  any[] = [];
let torneos:  any[] = [];
let ligas:    any[] = [];
let clubes:   any[] = [];

if (hasQuery) {
  const pattern = `%${q}%`;

  const [
    { data: pData },
    { data: tData },
    { data: lData },
    { data: cData },
  ] = await Promise.all([
    supabase
      .from('players')
      .select('id, nickname, slug, elo_rating, total_tournaments, total_podiums, countries ( name, flag_emoji )')
      .ilike('nickname', pattern)
      .eq('is_active', true)
      .order('elo_rating', { ascending: false })
      .limit(20),

    supabase
      .from('tournaments')
      .select('id, name, date, total_players, clubs ( name, slug ), rooms ( name )')
      .ilike('name', pattern)
      .eq('is_verified', true)
      .order('date', { ascending: false })
      .limit(10),

    supabase
      .from('leagues')
      .select('id, name, slug, description, clubs ( name, slug ), countries ( flag_emoji, name )')
      .ilike('name', pattern)
      .eq('is_active', true)
      .limit(10),

    supabase
      .from('clubs')
      .select('id, name, slug, description, countries ( flag_emoji, name ), rooms ( name )')
      .ilike('name', pattern)
      .eq('is_active', true)
      .limit(10),
  ]);

  players = pData ?? [];
  torneos = tData ?? [];
  ligas   = lData ?? [];
  clubes  = cData ?? [];
}

const totalResults = players.length + torneos.length + ligas.length + clubes.length;

function getEloBadge(elo: number) {
  if (elo >= 1800) return { cls: 'tier-legend',  label: 'LEGEND'  };
  if (elo >= 1600) return { cls: 'tier-master',  label: 'MASTER'  };
  if (elo >= 1400) return { cls: 'tier-diamond', label: 'DIAMOND' };
  if (elo >= 1300) return { cls: 'tier-gold',    label: 'GOLD'    };
  if (elo >= 1200) return { cls: 'tier-silver',  label: 'SILVER'  };
  if (elo >= 1100) return { cls: 'tier-bronze',  label: 'BRONZE'  };
  return              { cls: 'tier-entry',   label: 'ENTRY'   };
}

function fmtDate(d: string) {
  return new Date(d + 'T12:00:00').toLocaleDateString('es-CL', {
    day: '2-digit', month: 'short', year: 'numeric'
  }).toUpperCase();
}
---

<PublicLayout
  title="Buscar"
  description="Busca jugadores, torneos, ligas y clubes de póker en Sharkiana."
  noindex={false}
>

<section class="search-page">
  <div class="section-wrap">

    <!-- Header -->
    <div class="search-page-header">
      <div class="section-eyebrow">DIRECTORIO</div>
      <h1 class="section-title">BUSCAR</h1>
    </div>

    <!-- Search box -->
    <form method="get" action="/buscar" class="search-form">
      <div class="search-crystal-lg">
        <div class="search-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <input
          type="text"
          name="q"
          value={q}
          placeholder="JUGADOR, TORNEO, LIGA, CLUB..."
          class="search-input-lg"
          autofocus
          autocomplete="off"
        />
        {q && <a href="/buscar" class="search-clear">✕</a>}
        <button type="submit" class="search-submit">BUSCAR</button>
      </div>
      <div class="search-categories">
        <span class="sc-label">BUSCA EN:</span>
        <span class="sc-tag">JUGADORES</span>
        <span class="sc-dot">·</span>
        <span class="sc-tag">TORNEOS</span>
        <span class="sc-dot">·</span>
        <span class="sc-tag">LIGAS</span>
        <span class="sc-dot">·</span>
        <span class="sc-tag">CLUBES</span>
      </div>
    </form>

    <!-- Resumen resultados -->
    {hasQuery && (
      <div class="results-header">
        <span class="results-count">
          {totalResults > 0
            ? `${totalResults} resultado${totalResults !== 1 ? 's' : ''} para "${q}"`
            : `Sin resultados para "${q}"`
          }
        </span>
        {totalResults > 0 && (
          <div class="results-pills">
            {players.length > 0 && <span class="rpill rpill-player">{players.length} jugador{players.length !== 1 ? 'es' : ''}</span>}
            {torneos.length > 0 && <span class="rpill rpill-torneo">{torneos.length} torneo{torneos.length !== 1 ? 's' : ''}</span>}
            {ligas.length   > 0 && <span class="rpill rpill-liga">{ligas.length} liga{ligas.length !== 1 ? 's' : ''}</span>}
            {clubes.length  > 0 && <span class="rpill rpill-club">{clubes.length} club{clubes.length !== 1 ? 'es' : ''}</span>}
          </div>
        )}
      </div>
    )}

    <!-- ── JUGADORES ── -->
    {players.length > 0 && (
      <div class="results-section">
        <div class="rs-header">
          <span class="rs-icon rs-icon-player">👤</span>
          <span class="rs-title">JUGADORES</span>
          <span class="rs-count">{players.length}</span>
        </div>
        <div class="table-crystal">
          <div class="s-head s-head-player">
            <span>JUGADOR</span>
            <span class="col-tier">TIER</span>
            <span>ELO</span>
            <span class="col-stat">TORNEOS</span>
            <span class="col-stat">PODIOS</span>
          </div>
          <div class="t-body">
            {players.map(p => {
              const country = p.countries as { name: string; flag_emoji: string } | null;
              const badge   = getEloBadge(p.elo_rating ?? 1200);
              return (
                <a href={`/jugador/${p.slug}`} class="s-row s-row-player">
                  <div class="p-cell">
                    <div class="p-avatar">{p.nickname.charAt(0).toUpperCase()}</div>
                    <div class="p-info">
                      <span class="p-nick">{p.nickname}</span>
                      {country && <span class="p-country">{country.flag_emoji} {country.name}</span>}
                    </div>
                  </div>
                  <div class="col-tier"><span class={`tier ${badge.cls}`}>{badge.label}</span></div>
                  <div><span class="elo-num">{p.elo_rating ?? 1200}</span></div>
                  <div class="col-stat"><span class="stat-num">{p.total_tournaments ?? 0}</span></div>
                  <div class="col-stat"><span class="stat-num">{p.total_podiums ?? 0}</span></div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    )}

    <!-- ── TORNEOS ── -->
    {torneos.length > 0 && (
      <div class="results-section">
        <div class="rs-header">
          <span class="rs-icon">🃏</span>
          <span class="rs-title">TORNEOS</span>
          <span class="rs-count">{torneos.length}</span>
        </div>
        <div class="table-crystal">
          <div class="s-head s-head-torneo">
            <span>TORNEO</span>
            <span class="col-club-h">CLUB</span>
            <span>FECHA</span>
            <span class="col-stat">CAMPO</span>
          </div>
          <div class="t-body">
            {torneos.map((t: any) => {
              const club = t.clubs as { name: string; slug: string } | null;
              const room = t.rooms as { name: string } | null;
              return (
                <a href={`/torneo/${t.id}`} class="s-row s-row-torneo">
                  <div class="p-info">
                    <span class="p-nick">{t.name}</span>
                    {room && <span class="p-country">{room.name}</span>}
                  </div>
                  <div>
                    {club && <span class="club-tag">{club.name}</span>}
                  </div>
                  <div>
                    <span class="date-val">{fmtDate(t.date)}</span>
                  </div>
                  <div>
                    <span class="stat-num">{t.total_players} jug.</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    )}

    <!-- ── LIGAS ── -->
    {ligas.length > 0 && (
      <div class="results-section">
        <div class="rs-header">
          <span class="rs-icon">🏆</span>
          <span class="rs-title">LIGAS</span>
          <span class="rs-count">{ligas.length}</span>
        </div>
        <div class="table-crystal">
          <div class="s-head s-head-liga">
            <span>LIGA</span>
            <span class="col-club-h">CLUB</span>
            <span class="col-stat">PAÍS</span>
          </div>
          <div class="t-body">
            {ligas.map((l: any) => {
              const club    = l.clubs    as { name: string; slug: string } | null;
              const country = l.countries as { name: string; flag_emoji: string } | null;
              return (
                <a href={`/rankings/${l.slug}`} class="s-row s-row-liga">
                  <div class="p-info">
                    <span class="p-nick">{l.name}</span>
                    {l.description && <span class="p-country">{l.description.slice(0, 60)}{l.description.length > 60 ? '…' : ''}</span>}
                  </div>
                  <div>
                    {club && <span class="club-tag">{club.name}</span>}
                  </div>
                  <div>
                    {country && <span class="stat-num">{country.flag_emoji} {country.name}</span>}
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    )}

    <!-- ── CLUBES ── -->
    {clubes.length > 0 && (
      <div class="results-section">
        <div class="rs-header">
          <span class="rs-icon">🏠</span>
          <span class="rs-title">CLUBES</span>
          <span class="rs-count">{clubes.length}</span>
        </div>
        <div class="table-crystal">
          <div class="s-head s-head-club">
            <span>CLUB</span>
            <span class="col-club-h">SALA</span>
            <span class="col-stat">PAÍS</span>
          </div>
          <div class="t-body">
            {clubes.map((c: any) => {
              const country = c.countries as { name: string; flag_emoji: string } | null;
              const room    = c.rooms     as { name: string } | null;
              return (
                <a href={`/club/${c.slug}`} class="s-row s-row-club">
                  <div class="p-info">
                    <span class="p-nick">{c.name}</span>
                    {c.description && <span class="p-country">{c.description.slice(0, 60)}{c.description.length > 60 ? '…' : ''}</span>}
                  </div>
                  <div>
                    {room && <span class="club-tag">{room.name}</span>}
                  </div>
                  <div>
                    {country && <span class="stat-num">{country.flag_emoji} {country.name}</span>}
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    )}

    <!-- Sin resultados -->
    {hasQuery && totalResults === 0 && (
      <div class="no-results crystal">
        <div class="no-results-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <p class="no-results-title">SIN RESULTADOS</p>
        <p class="no-results-desc">No se encontró nada para "{q}" en jugadores, torneos, ligas ni clubes.</p>
      </div>
    )}

    <!-- Hint inicial -->
    {!hasQuery && (
      <div class="search-hint crystal">
        <p class="hint-text">Escribe al menos 2 caracteres para buscar en jugadores, torneos, ligas y clubes</p>
      </div>
    )}

  </div>
</section>

</PublicLayout>

<style>
.search-page { padding: 3rem 0 6rem; }
.search-page-header { margin-bottom: 2rem; }

/* ── Search box ── */
.search-form { margin-bottom: 0.75rem; }

.search-crystal-lg {
  display: flex;
  align-items: center;
  position: relative;
  background: rgba(255,255,255,0.09);
  backdrop-filter: blur(24px) saturate(200%);
  -webkit-backdrop-filter: blur(24px) saturate(200%);
  border: 1px solid rgba(255,255,255,0.20);
  border-radius: 12px;
  overflow: hidden;
  box-shadow:
    0 8px 32px rgba(0,0,0,0.4),
    inset 0 1px 0 rgba(255,255,255,0.28),
    inset 0 -1px 0 rgba(0,0,0,0.12);
  transition: all 0.3s;
}

.search-crystal-lg::before {
  content: '';
  position: absolute;
  top: 0; left: 8%; right: 8%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
  pointer-events: none;
  z-index: 1;
}

.search-crystal-lg:focus-within {
  border-color: rgba(0,229,255,0.45);
  box-shadow:
    0 8px 32px rgba(0,0,0,0.4),
    0 0 0 3px rgba(0,229,255,0.1),
    0 0 40px rgba(0,229,255,0.1),
    inset 0 1px 0 rgba(255,255,255,0.28);
}

.search-icon {
  padding: 0 0 0 1.5rem;
  color: rgba(0,229,255,0.5);
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.search-input-lg {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  padding: 1.1rem 1rem;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: #fff;
}

.search-input-lg::placeholder { color: rgba(255,255,255,0.25); }

.search-clear {
  padding: 0 1rem;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  font-size: 0.85rem;
  transition: color 0.2s;
  flex-shrink: 0;
}

.search-clear:hover { color: rgba(255,255,255,0.7); }

.search-submit {
  background: linear-gradient(135deg, #1a6aff, #00cfff);
  border: none;
  padding: 1.1rem 2rem;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  color: #fff;
  cursor: pointer;
  transition: opacity 0.2s;
  flex-shrink: 0;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
}

.search-submit:hover { opacity: 0.88; }

/* Categorías hint */
.search-categories {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
  margin-left: 4px;
}

.sc-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: rgba(255,255,255,0.25);
}

.sc-tag {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: rgba(0,229,255,0.5);
}

.sc-dot {
  color: rgba(255,255,255,0.15);
  font-size: 0.7rem;
}

/* ── Results header ── */
.results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1.75rem;
  margin-top: 1.25rem;
}

.results-count {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.5);
}

.results-pills {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.rpill {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  padding: 4px 10px;
  border-radius: 50px;
  border: 1px solid;
}

.rpill-player { color: #7dd3fc; border-color: rgba(125,211,252,0.3); background: rgba(56,189,248,0.08); }
.rpill-torneo { color: #fcd34d; border-color: rgba(252,211,77,0.3);  background: rgba(251,191,36,0.08); }
.rpill-liga   { color: #c4b5fd; border-color: rgba(196,181,253,0.3); background: rgba(167,139,250,0.08); }
.rpill-club   { color: #6ee7b7; border-color: rgba(110,231,183,0.3); background: rgba(52,211,153,0.08); }

/* ── Section agrupada ── */
.results-section { margin-bottom: 2rem; }

.rs-header {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.75rem;
  padding-left: 0.25rem;
}

.rs-icon { font-size: 1rem; }

.rs-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.22em;
  color: rgba(255,255,255,0.5);
}

.rs-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  color: rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 50px;
  padding: 1px 8px;
}

/* ── Table crystal compartida ── */
.table-crystal {
  position: relative;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(28px) saturate(200%);
  -webkit-backdrop-filter: blur(28px) saturate(200%);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 14px;
  overflow: hidden;
  box-shadow:
    0 24px 80px rgba(0,0,0,0.5),
    0 8px 24px rgba(0,0,0,0.3),
    inset 0 1px 0 rgba(255,255,255,0.22);
}

.table-crystal::before {
  content: '';
  position: absolute;
  top: 0; left: 5%; right: 5%;
  height: 1px;
  background: linear-gradient(90deg,
    transparent, rgba(255,255,255,0.55) 30%,
    rgba(255,255,255,0.85) 50%,
    rgba(255,255,255,0.55) 70%, transparent
  );
  z-index: 2;
  pointer-events: none;
}

/* Grids por tipo */
.s-head {
  padding: 0.9rem 1.5rem;
  background: rgba(41,121,255,0.09);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  display: grid;
}

.s-head span {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: rgba(0,229,255,0.9);
}

.s-head-player { grid-template-columns: 1fr 120px 100px 90px 90px; }
.s-head-torneo { grid-template-columns: 1fr 160px 120px 80px; }
.s-head-liga   { grid-template-columns: 1fr 180px 120px; }
.s-head-club   { grid-template-columns: 1fr 160px 120px; }

.t-body { display: flex; flex-direction: column; }

.s-row {
  display: grid;
  align-items: center;
  padding: 0 1.5rem;
  height: 64px;
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  position: relative;
  overflow: hidden;
  transition: background 0.2s;
  cursor: pointer;
}

/* Cada tipo hereda el mismo grid del head */
.s-row-player { grid-template-columns: 1fr 120px 100px 90px 90px; }
.s-row-torneo { grid-template-columns: 1fr 160px 120px 80px; }
.s-row-liga   { grid-template-columns: 1fr 180px 120px; }
.s-row-club   { grid-template-columns: 1fr 160px 120px; }

.s-row:last-child { border-bottom: none; }
.s-row:hover { background: rgba(255,255,255,0.05); }

.s-row::before {
  content: '';
  position: absolute;
  left: 0; top: 50%;
  transform: translateY(-50%);
  width: 3px; height: 0;
  background: linear-gradient(180deg, var(--accent), var(--accent2));
  border-radius: 0 2px 2px 0;
  transition: height 0.2s;
}

.s-row:hover::before { height: 60%; }

/* Cells */
.p-cell { display: flex; align-items: center; gap: 1rem; min-width: 0; }

.p-avatar {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(41,121,255,0.25), rgba(0,229,255,0.15));
  border: 1px solid rgba(0,229,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  color: #fff;
  flex-shrink: 0;
}

.p-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; justify-content: center; }

.p-nick {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: color 0.15s;
}

.s-row:hover .p-nick { color: var(--accent2); }

.p-country {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.65rem;
  color: rgba(255,255,255,0.5);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.elo-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.95rem;
  font-weight: 700;
  color: #fff;
}

.stat-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.6);
}

.date-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  color: rgba(255,255,255,0.55);
  white-space: nowrap;
}

.club-tag {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: rgba(0,229,255,0.7);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

/* No results / hint */
.no-results, .search-hint {
  padding: 4rem 2rem;
  text-align: center;
  border-radius: 14px;
  margin-top: 1rem;
}

.no-results-icon {
  color: rgba(255,255,255,0.15);
  margin-bottom: 1.5rem;
  display: flex;
  justify-content: center;
}

.no-results-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.2em;
  color: rgba(255,255,255,0.3);
  margin-bottom: 0.5rem;
