---
// src/pages/index.astro
import PublicLayout from '@layouts/PublicLayout.astro';
import CountryFlag from '@components/CountryFlag.astro';
import { createServerClient } from '@lib/supabase/server';

const supabase = createServerClient();

const [
  { data: players },
  { count: totalTournaments },
  { count: totalClubs },
  { count: totalLeagues },
] = await Promise.all([
  supabase.rpc('get_global_ranking', { p_limit: 100, p_offset: 0 }),
  supabase.from('tournaments').select('*', { count: 'exact', head: true }).eq('is_verified', true),
  supabase.from('clubs').select('*', { count: 'exact', head: true }).eq('is_active', true),
  supabase.from('leagues').select('*', { count: 'exact', head: true }).eq('is_active', true),
]);

function getEloBadge(elo: number) {
  if (elo >= 1800) return { cls: 'tier-legend',  label: 'LEGEND'  };
  if (elo >= 1600) return { cls: 'tier-master',  label: 'MASTER'  };
  if (elo >= 1400) return { cls: 'tier-diamond', label: 'DIAMOND' };
  if (elo >= 1300) return { cls: 'tier-gold',    label: 'GOLD'    };
  if (elo >= 1200) return { cls: 'tier-silver',  label: 'SILVER'  };
  if (elo >= 1100) return { cls: 'tier-bronze',  label: 'BRONZE'  };
  return              { cls: 'tier-entry',   label: 'ENTRY'   };
}

function topClass(i: number) {
  if (i === 0) return 'top-1';
  if (i === 1) return 'top-2';
  if (i === 2) return 'top-3';
  return '';
}

function rankClass(i: number) {
  if (i === 0) return 'r-num gold';
  if (i === 1) return 'r-num silver';
  if (i === 2) return 'r-num bronze';
  return 'r-num';
}

// ── Pre-procesar rows ──────────────────────
type RowItem = {
  slug: string; rowCls: string; rankCls: string; rankStr: string;
  countryFlag: string; nickname: string; countryCode: string;
  badgeCls: string; badgeLabel: string; eloRating: number;
  totalTournaments: number; winPct: number; totalPodiums: number;
};

const rows: RowItem[] = (players ?? []).map((p: any, i: number) => {
  const badge  = getEloBadge(p.elo_rating);
  const winPct = p.total_tournaments > 0
    ? Math.round((p.total_podiums / p.total_tournaments) * 100)
    : 0;
  return {
    slug:             p.slug,
    rowCls:           `t-row ${topClass(i)}`,
    rankCls:          rankClass(i),
    rankStr:          String(i + 1).padStart(2, '0'),
    countryFlag:      p.country_flag ?? '',
    nickname:         p.nickname,
    countryCode:      p.country_code ?? '',
    badgeCls:         badge.cls,
    badgeLabel:       badge.label,
    eloRating:        p.elo_rating,
    totalTournaments: p.total_tournaments,
    winPct,
    totalPodiums:     p.total_podiums,
  };
});
---

<PublicLayout
  title="Sharkania — El ranking del póker hispano"
  description="La base de datos definitiva de resultados de póker online para jugadores de habla hispana. Rankings ELO, torneos y estadísticas."
>

<!-- ── HERO ─────────────────────────────────── -->
<section class="hero">
  <div class="live-badge">
    <div class="live-dot"></div>
    RANKING OFICIAL · TEMPORADA 2026
  </div>

  <h1 class="hero-title">
    <span class="t-main">SHARKANIA</span>
    <span class="t-sub">EL RANKING DEL PÓKER HISPANO</span>
  </h1>

  <p class="hero-desc">
    El ranking competitivo de <strong>Clubes Online</strong> de habla hispana.<br/>
    Sistema ELO · Torneos · Ligas · Clasificación global unificada.
  </p>

  <a href="/unirse" class="join-cta">
    🃏 Quiero que mi Club sea parte de Sharkania
  </a>

  <div class="hero-search-wrap">
    <form action="/buscar" method="get" class="search-crystal">
      <input
        class="s-input"
        type="text"
        name="q"
        placeholder="BUSCAR JUGADOR POR NICK..."
        autocomplete="off"
      />
      <button type="submit" class="s-btn">BUSCAR</button>
    </form>
  </div>

  <div class="hero-stats">
    <a href="/rankings/global" class="stat-crystal stat-link">
      <span class="stat-n">{players?.length ?? 0}</span>
      <span class="stat-l">JUGADORES</span>
      <span class="stat-arrow">→</span>
    </a>
    <a href="/torneos" class="stat-crystal stat-link">
      <span class="stat-n">{totalTournaments ?? 0}</span>
      <span class="stat-l">TORNEOS EJECUTADOS</span>
      <span class="stat-arrow">→</span>
    </a>
    <a href="/calendario" class="stat-crystal stat-link">
      <span class="stat-n">📅</span>
      <span class="stat-l">CALENDARIO</span>
      <span class="stat-arrow">→</span>
    </a>
    <a href="/ligas" class="stat-crystal stat-link">
      <span class="stat-n">{totalLeagues ?? 0}</span>
      <span class="stat-l">LIGAS</span>
      <span class="stat-arrow">→</span>
    </a>
    <a href="/clubes" class="stat-crystal stat-link">
      <span class="stat-n">{totalClubs ?? 0}</span>
      <span class="stat-l">CLUBES</span>
      <span class="stat-arrow">→</span>
    </a>
  </div>
</section>

<!-- ── RANKING ───────────────────────────────── -->
<section class="ranking-section">
  <div class="section-wrap">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">CLASIFICACIÓN GLOBAL</div>
        <div class="section-title">TOP 100 JUGADORES</div>
      </div>
      <a href="/rankings/global" class="section-link">VER RANKING COMPLETO</a>
    </div>

    <div class="table-crystal">
      <div class="t-head">
        <span>POS</span>
        <span>JUGADOR</span>
        <span class="col-tier">TIER</span>
        <span>ELO</span>
        <span class="col-stat">TORNEOS</span>
        <span class="col-stat">WIN%</span>
        <span class="col-stat">PODIOS</span>
      </div>

      <div class="t-body">
        {rows.map(r => (
          <a href={`/jugador/${r.slug}`} class={r.rowCls}>
            <div><span class={r.rankCls}>{r.rankStr}</span></div>
            <div class="p-cell">
              <span class="p-flag">
  {r.countryCode ? (
    <CountryFlag countryCode={r.countryCode} size={20} />
  ) : null}
</span>
              <div class="p-info">
                <span class="p-nick">{r.nickname}</span>
                <span class="p-country">{r.countryCode}</span>
              </div>
            </div>
            <div class="col-tier">
              <span class={`tier ${r.badgeCls}`}>{r.badgeLabel}</span>
            </div>
            <div><span class="elo-val">{r.eloRating}</span></div>
            <div><span class="s-val col-stat">{r.totalTournaments}</span></div>
            <div><span class="s-val col-stat">{r.winPct}%</span></div>
            <div><span class="s-val col-stat">{r.totalPodiums}</span></div>
          </a>
        ))}
        {rows.length === 0 && (
          <div class="t-empty">NO HAY JUGADORES RANKEADOS AÚN</div>
        )}
      </div>
    </div>
  </div>
</section>

</PublicLayout>

<style>
/* ── Hero ─────────────────────────────────── */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - var(--nav-h));
  padding: 4rem 2rem 0;
  text-align: center;
}

.live-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 50px;
  padding: 7px 18px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: #fff;
  margin-bottom: 2rem;
  box-shadow: 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.22);
  animation: fadeDown 0.8s ease both;
}

.live-dot {
  width: 7px; height: 7px;
  background: var(--accent2);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--accent2), 0 0 16px rgba(0,229,255,0.5);
  animation: pulse 1.8s infinite;
}

.join-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
  padding: 10px 24px;
  background: linear-gradient(135deg, rgba(41,121,255,0.15), rgba(0,229,255,0.08));
  border: 1px solid rgba(41,121,255,0.35);
  border-radius: 50px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  transition: background 0.2s, border-color 0.2s, transform 0.2s;
  animation: fadeDown 0.8s 0.2s ease both;
}
.join-cta:hover {
  background: linear-gradient(135deg, rgba(41,121,255,0.25), rgba(0,229,255,0.15));
  border-color: rgba(0,229,255,0.5);
  transform: translateY(-2px);
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50%       { transform: scale(1.3); opacity: 0.6; }
}

.hero-title { margin: 0 0 1.25rem; animation: fadeDown 0.8s 0.1s ease both; }

.t-main {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(5rem, 14vw, 11rem);
  font-weight: 900;
  line-height: 0.85;
  letter-spacing: -0.01em;
  background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.92) 35%, rgba(180,220,255,0.8) 70%, rgba(100,180,255,0.65) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 2px 40px rgba(41,121,255,0.45)) drop-shadow(0 0 80px rgba(0,229,255,0.15));
}

.t-sub {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(0.85rem, 1.8vw, 1.1rem);
  font-weight: 600;
  letter-spacing: 0.3em;
  color: var(--accent2);
  margin-top: 0.75rem;
  text-shadow: 0 0 20px rgba(0,229,255,0.45);
}

.hero-desc {
  font-size: 0.97rem;
  color: var(--text-dim);
  line-height: 1.8;
  margin: 0 auto 2.5rem;
  max-width: 460px;
  animation: fadeDown 0.8s 0.2s ease both;
}

.hero-search-wrap {
  width: 100%;
  max-width: 580px;
  margin: 0 auto 5rem;
  animation: fadeDown 0.8s 0.3s ease both;
}

.search-crystal {
  display: flex;
  position: relative;
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(24px) saturate(200%);
  -webkit-backdrop-filter: blur(24px) saturate(200%);
  border: 1px solid rgba(255,255,255,0.22);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.28), inset 0 -1px 0 rgba(0,0,0,0.15);
  transition: all 0.3s;
}

.search-crystal::before {
  content: '';
  position: absolute;
  top: 0; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
  pointer-events: none;
  z-index: 1;
}

.search-crystal:focus-within {
  border-color: rgba(0,229,255,0.45);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 3px rgba(0,229,255,0.1), 0 0 40px rgba(0,229,255,0.12), inset 0 1px 0 rgba(255,255,255,0.28);
}

.s-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  padding: 16px 22px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 0.09em;
  color: #fff;
}

.s-input::placeholder { color: rgba(255,255,255,0.22); }

.s-btn {
  background: linear-gradient(135deg, #1a6aff, #00cfff);
  border: none;
  padding: 16px 30px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  color: #fff;
  cursor: pointer;
  transition: opacity 0.2s;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
  flex-shrink: 0;
}

.s-btn:hover { opacity: 0.88; }

.hero-stats {
  display: flex;
  gap: 12px;
  width: 100%;
  max-width: 660px;
  animation: fadeDown 0.8s 0.4s ease both;
}

.stat-crystal {
  flex: 1;
  position: relative;
  background: rgba(255,255,255,0.09);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255,255,255,0.17);
  border-radius: 10px;
  padding: 1.6rem 1rem;
  text-align: center;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.26), inset 0 -1px 0 rgba(0,0,0,0.12);
  transition: transform 0.2s, box-shadow 0.2s;
}

.stat-crystal:hover {
  transform: translateY(-3px);
  box-shadow: 0 14px 36px rgba(0,0,0,0.4), 0 0 28px rgba(41,121,255,0.12), inset 0 1px 0 rgba(255,255,255,0.3);
}

.stat-crystal::before {
  content: '';
  position: absolute;
  top: 0; left: 8%; right: 8%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55), transparent);
  pointer-events: none;
}

.stat-n {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.8rem;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 0.4rem;
  background: linear-gradient(180deg, #fff 0%, rgba(180,220,255,0.9) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 12px rgba(41,121,255,0.35));
}

.stat-l {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--accent2);
  text-shadow: 0 0 10px rgba(0,229,255,0.35);
}

/* ── Ranking section ─────────────────────── */
.ranking-section { padding: 5rem 0 6rem; }

.table-crystal {
  position: relative;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(28px) saturate(200%);
  -webkit-backdrop-filter: blur(28px) saturate(200%);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 14px;
  overflow: hidden;
  box-shadow:
    0 24px 80px rgba(0,0,0,0.5),
    0 8px 24px rgba(0,0,0,0.3),
    inset 0 1px 0 rgba(255,255,255,0.22),
    inset 0 -1px 0 rgba(0,0,0,0.15),
    inset 1px 0 0 rgba(255,255,255,0.05),
    inset -1px 0 0 rgba(255,255,255,0.05);
}

.table-crystal::before {
  content: '';
  position: absolute;
  top: 0; left: 5%; right: 5%;
  height: 1px;
  background: linear-gradient(90deg,
    transparent 0%, rgba(255,255,255,0.5) 20%,
    rgba(255,255,255,0.85) 50%, rgba(255,255,255,0.5) 80%, transparent 100%
  );
  z-index: 2;
  pointer-events: none;
}

.table-crystal::after {
  content: '';
  position: absolute;
  top: 0; left: -1px;
  width: 3px; height: 100%;
  background: linear-gradient(180deg,
    rgba(41,121,255,0.7), rgba(0,229,255,0.4), rgba(41,121,255,0.2), transparent
  );
  border-radius: 14px 0 0 14px;
}

.t-head {
  display: grid;
  grid-template-columns: 72px 1fr 120px 110px 90px 90px 90px;
  padding: 1rem 1.5rem;
  background: rgba(41,121,255,0.09);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  position: relative;
}

.t-head::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg,
    transparent, rgba(0,229,255,0.25), rgba(41,121,255,0.4), rgba(0,229,255,0.25), transparent
  );
}

.t-head span {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: rgba(0,229,255,0.4);
}

.t-body { display: flex; flex-direction: column; }

.t-row {
  display: grid;
  grid-template-columns: 72px 1fr 120px 110px 90px 90px 90px;
  align-items: center;
  padding: 0 1.5rem;
  height: 64px;
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  position: relative;
  overflow: hidden;
  transition: background 0.2s;
  cursor: pointer;
}

.t-row::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), rgba(255,255,255,0.07), transparent);
  transition: left 0.5s ease;
  pointer-events: none;
}

.t-row:hover::after { left: 140%; }
.t-row:hover { background: rgba(255,255,255,0.05); }

.t-row::before {
  content: '';
  position: absolute;
  left: 0; top: 50%;
  transform: translateY(-50%);
  width: 3px; height: 0;
  border-radius: 0 2px 2px 0;
  background: linear-gradient(180deg, var(--accent), var(--accent2));
  transition: height 0.25s;
  z-index: 1;
}

.t-row:hover::before { height: 65%; }

.t-row.top-1 { background: linear-gradient(90deg, rgba(232,197,90,0.09) 0%, rgba(232,197,90,0.03) 40%, transparent 70%); }
.t-row.top-1::before { height: 65%; background: linear-gradient(180deg, #e8c55a, #f7e08a); box-shadow: 0 0 12px rgba(232,197,90,0.5); }
.t-row.top-2 { background: linear-gradient(90deg, rgba(180,195,210,0.07) 0%, transparent 60%); }
.t-row.top-2::before { height: 65%; background: linear-gradient(180deg, #b0c4d8, #d8e8f5); }
.t-row.top-3 { background: linear-gradient(90deg, rgba(200,140,90,0.07) 0%, transparent 60%); }
.t-row.top-3::before { height: 65%; background: linear-gradient(180deg, #c88050, #e0aa7a); }

.r-num { font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; font-weight: 800; color: rgba(255,255,255,0.55); letter-spacing: 0.05em; }
.r-num.gold   { font-size: 1.2rem; background: linear-gradient(180deg, #f7e08a, #c9a84c); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; filter: drop-shadow(0 0 8px rgba(232,197,90,0.55)); }
.r-num.silver { font-size: 1.1rem; background: linear-gradient(180deg, #e0eefc, #90afc8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.r-num.bronze { font-size: 1.05rem; background: linear-gradient(180deg, #e0aa7a, #a06030); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

.p-cell { display: flex; align-items: center; gap: 0.85rem; min-width: 0; }
.p-flag { font-size: 1.2rem; flex-shrink: 0; }
.p-info { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.p-nick { font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; font-weight: 700; color: #fff; letter-spacing: 0.03em; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color 0.15s, text-shadow 0.15s; }
.t-row:hover .p-nick { color: var(--accent2); text-shadow: 0 0 16px rgba(0,229,255,0.35); }
.p-country { font-family: 'Barlow Condensed', sans-serif; font-size: 0.64rem; font-weight: 600; letter-spacing: 0.1em; color: rgba(255,255,255,0.5); text-transform: uppercase; }

.elo-val { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; font-weight: 700; color: #fff; }
.t-row.top-1 .elo-val { background: linear-gradient(180deg, #f7e08a, #c9a84c); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; filter: drop-shadow(0 0 8px rgba(232,197,90,0.4)); }

.s-val { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; color: var(--text-dim); }

.t-row { animation: rowIn 0.45s ease both; }
@keyframes rowIn { from { opacity: 0; transform: translateX(-8px); } to { opacity: 1; transform: translateX(0); } }
.t-row:nth-child(1)  { animation-delay: 0.04s; }
.t-row:nth-child(2)  { animation-delay: 0.08s; }
.t-row:nth-child(3)  { animation-delay: 0.12s; }
.t-row:nth-child(4)  { animation-delay: 0.16s; }
.t-row:nth-child(5)  { animation-delay: 0.20s; }
.t-row:nth-child(6)  { animation-delay: 0.24s; }
.t-row:nth-child(7)  { animation-delay: 0.28s; }
.t-row:nth-child(8)  { animation-delay: 0.32s; }
.t-row:nth-child(9)  { animation-delay: 0.36s; }
.t-row:nth-child(10) { animation-delay: 0.40s; }
.t-row:nth-child(n+11) { animation-delay: 0.44s; }

.t-empty { padding: 4rem; text-align: center; font-family: 'Barlow Condensed', sans-serif; font-size: 0.85rem; letter-spacing: 0.18em; color: rgba(255,255,255,0.2); }

@media (max-width: 900px) {
  .t-head, .t-row { grid-template-columns: 56px 1fr 100px 90px; }
  .col-stat { display: none; }
}

@media (max-width: 640px) {
  .hero { padding: 3rem 1rem 0; }
  .hero-stats { flex-direction: column; }
  .t-head, .t-row { grid-template-columns: 48px 1fr 85px; }
  .col-tier { display: none; }
}
</style>