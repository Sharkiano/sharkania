  border-radius: 8px;
  background: linear-gradient(135deg, #ffd740, #f5af19);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  flex-shrink: 0;
}

.league-item-body  { flex: 1; }
.league-item-name  { font-size: 0.875rem; font-weight: 500; color: #e4e4ef; }
.league-item-dates { font-size: 0.75rem; margin-top: 2px; font-family: 'JetBrains Mono', monospace; }
</style>