---
// src/pages/ligas.astro
import PublicLayout from '@layouts/PublicLayout.astro';
import { createServerClient } from '@lib/supabase/server';

const supabase = createServerClient();

const { data: ligas } = await supabase
  .from('leagues')
  .select(`
    id, name, slug, description, season_start, season_end,
    clubs ( name, slug, countries ( name, flag_emoji ) )
  `)
  .eq('is_active', true)
  .order('name', { ascending: true });

// Contar torneos y jugadores por liga
const { data: tourneyCounts } = await supabase
  .from('tournaments')
  .select('league_id')
  .eq('is_verified', true)
  .not('league_id', 'is', null);

const { data: standingCounts } = await supabase
  .from('league_standings')
  .select('league_id');

const torneoMap = new Map<number, number>();
(tourneyCounts ?? []).forEach((t: any) => {
  torneoMap.set(t.league_id, (torneoMap.get(t.league_id) ?? 0) + 1);
});

const playerMap = new Map<number, number>();
(standingCounts ?? []).forEach((s: any) => {
  playerMap.set(s.league_id, (playerMap.get(s.league_id) ?? 0) + 1);
});

type Liga = {
  id: number;
  name: string;
  slug: string;
  description: string;
  seasonStart: string | null;
  seasonEnd: string | null;
  clubName: string;
  clubSlug: string;
  countryFlag: string;
  countryName: string;
  torneos: number;
  jugadores: number;
};

const processed: Liga[] = (ligas ?? []).map((l: any) => {
  const club    = l.clubs as any;
  const country = club?.countries as any;
  return {
    id:          l.id,
    name:        l.name,
    slug:        l.slug,
    description: l.description ?? '',
    seasonStart: l.season_start,
    seasonEnd:   l.season_end,
    clubName:    club?.name  ?? '',
    clubSlug:    club?.slug  ?? '',
    countryFlag: country?.flag_emoji ?? '',
    countryName: country?.name ?? '',
    torneos:     torneoMap.get(l.id) ?? 0,
    jugadores:   playerMap.get(l.id) ?? 0,
  };
});

function fmtSeason(start: string | null, end: string | null) {
  if (!start && !end) return null;
  const fmt = (d: string) => new Date(d + 'T12:00:00').toLocaleDateString('es-CL', {
    month: 'short', year: 'numeric'
  }).toUpperCase();
  if (start && end) return `${fmt(start)} — ${fmt(end)}`;
  if (start) return `DESDE ${fmt(start)}`;
  return `HASTA ${fmt(end!)}`;
}
---

<PublicLayout
  title="Ligas de póker"
  description="Directorio de ligas y circuitos de póker online en Sharkiana. Rankings, clasificaciones y temporadas de clubes hispanos."
>

<section class="ligas-page">
  <div class="section-wrap">

    <div class="page-header">
      <div>
        <div class="section-eyebrow">CIRCUITOS</div>
        <h1 class="section-title">LIGAS</h1>
      </div>
      <span class="total-badge">{processed.length} LIGAS ACTIVAS</span>
    </div>

    {processed.length > 0 ? (
      <div class="ligas-grid">
        {processed.map(l => (
          <a href={`/rankings/${l.slug}`} class="liga-card crystal">

            <div class="lc-top">
              <div class="lc-icon">🏆</div>
              <div class="lc-meta">
                {l.countryFlag && (
                  <span class="lc-country">{l.countryFlag} {l.countryName}</span>
                )}
                {fmtSeason(l.seasonStart, l.seasonEnd) && (
                  <span class="lc-season">{fmtSeason(l.seasonStart, l.seasonEnd)}</span>
                )}
              </div>
            </div>

            <div class="lc-name">{l.name}</div>

            {l.clubSlug ? (
              <span class="lc-club">{l.clubName}</span>
            ) : null}

            {l.description && (
              <p class="lc-desc">{l.description}</p>
            )}

            <div class="lc-footer">
              <div class="lc-stats">
                <span class="lc-stat">
                  <span class="lc-stat-n">{l.torneos}</span>
                  <span class="lc-stat-l">TORNEOS</span>
                </span>
                <span class="lc-divider">·</span>
                <span class="lc-stat">
                  <span class="lc-stat-n">{l.jugadores}</span>
                  <span class="lc-stat-l">JUGADORES</span>
                </span>
              </div>
              <span class="lc-arrow">VER RANKING →</span>
            </div>

          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state crystal">
        <p class="empty-text">NO HAY LIGAS ACTIVAS AÚN</p>
      </div>
    )}

  </div>
</section>

</PublicLayout>

<style>
.ligas-page { padding: 3rem 0 6rem; }

.page-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 2rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.total-badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: #c4b5fd;
  background: rgba(196,181,253,0.08);
  border: 1px solid rgba(196,181,253,0.2);
  padding: 6px 14px;
  border-radius: 50px;
  backdrop-filter: blur(8px);
}

.ligas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
}

/* Liga card */
.liga-card {
  padding: 1.5rem;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  border-radius: 14px;
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
}

.liga-card:hover {
  transform: translateY(-4px);
  border-color: rgba(196,181,253,0.4);
  box-shadow:
    0 20px 60px rgba(0,0,0,0.5),
    0 0 30px rgba(167,139,250,0.12);
}

.lc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lc-icon {
  font-size: 1.8rem;
  filter: drop-shadow(0 0 10px rgba(196,181,253,0.4));
}

.lc-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.3rem;
}

.lc-country {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  color: rgba(255,255,255,0.65);
}

.lc-season {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.58rem;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.05em;
}

.lc-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.35rem;
  font-weight: 900;
  color: #fff;
  letter-spacing: 0.03em;
  line-height: 1.1;
  transition: color 0.15s;
}

.liga-card:hover .lc-name { color: #c4b5fd; }

.lc-club {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--accent2);
  opacity: 0.7;
  background: rgba(0,229,255,0.06);
  border: 1px solid rgba(0,229,255,0.12);
  padding: 2px 10px;
  border-radius: 20px;
  align-self: flex-start;
}

.lc-desc {
  font-family: 'Barlow', sans-serif;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.lc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.lc-stats {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.lc-stat {
  display: flex;
  align-items: baseline;
  gap: 0.3rem;
}

.lc-stat-n {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
}

.lc-stat-l {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: rgba(255,255,255,0.55);
}

.lc-divider {
  color: var(--text-faint);
  font-size: 0.8rem;
}

.lc-arrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  color: #c4b5fd;
  opacity: 0.7;
  transition: opacity 0.2s, letter-spacing 0.2s;
}

.liga-card:hover .lc-arrow {
  opacity: 1;
  letter-spacing: 0.22em;
}

/* Empty */
.empty-state { padding: 4rem; text-align: center; }
.empty-text {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: rgba(255,255,255,0.18);
}

@media (max-width: 640px) {
  .ligas-grid { grid-template-columns: 1fr; }
}
</style>