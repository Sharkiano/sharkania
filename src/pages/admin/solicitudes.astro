---
// src/pages/admin/solicitudes.astro
import AdminLayout from '@layouts/AdminLayout.astro';
import { createServerClient } from '@lib/supabase/server';

const supabase = createServerClient();

const { data: requests } = await (supabase as any)
  .from('club_requests')
  .select('*, countries ( name, flag_emoji )')
  .order('created_at', { ascending: false });

const pending  = requests?.filter((r: any) => r.status === 'pending')  ?? [];
const reviewed = requests?.filter((r: any) => r.status !== 'pending')  ?? [];
---

<AdminLayout title="Solicitudes de Clubes">

  <div class="page-header">
    <div>
      <h2 class="page-title">Solicitudes de Clubes</h2>
      {pending.length > 0 && (
        <span class="badge-pending">{pending.length} pendiente{pending.length > 1 ? 's' : ''}</span>
      )}
    </div>
  </div>

  {pending.length > 0 && (
    <div class="requests-section">
      <h3 class="section-sub">Pendientes de revisión</h3>
      <div class="requests-list">
        {pending.map((r: any) => (
          <div class="request-card glass-card" id={`req-${r.id}`}>
            <div class="req-header">
              <div class="req-club-name">{r.club_name}</div>
              <div class="req-date">{new Date(r.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</div>
            </div>

            <div class="req-grid">
              <div class="req-field">
                <span class="req-label">Administrador</span>
                <span class="req-value">{r.admin_name ?? '—'}</span>
              </div>
              <div class="req-field">
                <span class="req-label">País</span>
                <span class="req-value">{r.countries?.flag_emoji} {r.countries?.name ?? '—'}</span>
              </div>
              <div class="req-field">
                <span class="req-label">Sala</span>
                <span class="req-value">{r.room_name}</span>
              </div>
              <div class="req-field">
                <span class="req-label">Email</span>
                <span class="req-value"><a href={`mailto:${r.email}`} class="req-link">{r.email}</a></span>
              </div>
              <div class="req-field">
                <span class="req-label">WhatsApp</span>
                <span class="req-value"><a href={`https://wa.me/${r.whatsapp.replace(/\D/g,'')}`} target="_blank" class="req-link">{r.whatsapp}</a></span>
              </div>
              {r.telegram && (
                <div class="req-field">
                  <span class="req-label">Telegram</span>
                  <span class="req-value">{r.telegram}</span>
                </div>
              )}
              {r.instagram && (
                <div class="req-field">
                  <span class="req-label">Instagram</span>
                  <span class="req-value">{r.instagram}</span>
                </div>
              )}
              <div class="req-field req-field--full">
                <span class="req-label">Descripción</span>
                <span class="req-value req-desc">{r.description}</span>
              </div>
            </div>

            <div class="req-actions">
              <button
                class="btn btn-danger"
                data-id={String(r.id)}
                onclick="rejectRequest(this)"
              >✕ Rechazar</button>
              <button
                class="btn btn-success"
                data-id={String(r.id)}
                data-club={r.club_name}
                data-country={String(r.countries?.id ?? r.country_id ?? '')}
                data-room={r.room_name}
                data-desc={r.description}
                data-email={r.email}
                data-whatsapp={r.whatsapp}
                onclick="approveRequest(this)"
              >✓ Aprobar y crear club</button>
            </div>

            <div class="req-feedback" id={`feedback-${r.id}`}></div>
          </div>
        ))}
      </div>
    </div>
  )}

  {pending.length === 0 && (
    <div class="empty-state" style="padding:3rem;">
      <p style="font-size:2rem;margin:0;">🎉</p>
      <p>No hay solicitudes pendientes.</p>
    </div>
  )}

  {reviewed.length > 0 && (
    <div class="requests-section" style="margin-top:2.5rem;">
      <h3 class="section-sub" style="color:rgba(255,255,255,0.3);">Revisadas</h3>
      <div class="requests-list">
        {reviewed.map((r: any) => (
          <div class="request-card glass-card request-card--reviewed">
            <div class="req-header">
              <div class="req-club-name" style="opacity:0.5;">{r.club_name}</div>
              <span class={`status-badge status-badge--${r.status}`}>
                {r.status === 'approved' ? '✓ Aprobado' : '✕ Rechazado'}
              </span>
            </div>
            <div class="req-grid" style="opacity:0.4;">
              <div class="req-field">
                <span class="req-label">País</span>
                <span class="req-value">{r.countries?.flag_emoji} {r.countries?.name ?? '—'}</span>
              </div>
              <div class="req-field">
                <span class="req-label">Email</span>
                <span class="req-value">{r.email}</span>
              </div>
              <div class="req-field">
                <span class="req-label">Fecha</span>
                <span class="req-value">{new Date(r.created_at).toLocaleDateString('es-ES')}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

</AdminLayout>

<style>
.badge-pending {
  display: inline-block;
  background: rgba(255,82,82,0.15);
  border: 1px solid rgba(255,82,82,0.35);
  color: #ff5252;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 3px 10px;
  border-radius: 20px;
  margin-left: 0.75rem;
  vertical-align: middle;
}

.section-sub {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: rgba(255,255,255,0.4);
  margin-bottom: 1rem;
}

.requests-list  { display: flex; flex-direction: column; gap: 1.25rem; }

.request-card {
  padding: 1.5rem;
  border-radius: 12px;
}
.request-card--reviewed { opacity: 0.7; }

.req-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.25rem;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.req-club-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.3rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: 0.04em;
}
.req-date {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.3);
}

.req-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.85rem 1.5rem;
  margin-bottom: 1.25rem;
}
.req-field         { display: flex; flex-direction: column; gap: 3px; }
.req-field--full   { grid-column: 1 / -1; }
.req-label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: rgba(255,255,255,0.25);
  text-transform: uppercase;
}
.req-value  { font-size: 0.9rem; color: rgba(255,255,255,0.75); }
.req-desc   { white-space: pre-wrap; line-height: 1.6; font-size: 0.85rem; color: rgba(255,255,255,0.6); }
.req-link   { color: #448aff; text-decoration: none; }
.req-link:hover { text-decoration: underline; }

.req-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.btn-success {
  background: rgba(0,230,118,0.12);
  border: 1px solid rgba(0,230,118,0.35);
  color: #00e676;
  padding: 9px 20px;
  border-radius: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-success:hover    { background: rgba(0,230,118,0.2); }
.btn-success:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-danger {
  background: rgba(255,82,82,0.08);
  border: 1px solid rgba(255,82,82,0.25);
  color: #ff5252;
  padding: 9px 20px;
  border-radius: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-danger:hover    { background: rgba(255,82,82,0.15); }
.btn-danger:disabled { opacity: 0.5; cursor: not-allowed; }

.req-feedback {
  margin-top: 0.75rem;
  font-size: 0.82rem;
  min-height: 1.2em;
}

.status-badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 3px 10px;
  border-radius: 20px;
}
.status-badge--approved {
  background: rgba(0,230,118,0.1);
  border: 1px solid rgba(0,230,118,0.3);
  color: #00e676;
}
.status-badge--rejected {
  background: rgba(255,82,82,0.1);
  border: 1px solid rgba(255,82,82,0.3);
  color: #ff5252;
}
</style>

<script>
async function approveRequest(btn: HTMLElement) {
  if (!confirm(`¿Aprobar y crear el club "${btn.dataset.club}"?`)) return;

  const id       = btn.dataset.id!;
  const feedback = document.getElementById(`feedback-${id}`)!;
  const allBtns  = document.querySelectorAll<HTMLButtonElement>(`#req-${id} button`);

  allBtns.forEach(b => b.disabled = true);
  feedback.textContent = 'Creando club...';
  feedback.style.color = 'rgba(255,255,255,0.4)';

  try {
    const res  = await fetch('/api/admin/solicitudes', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({
        id:         Number(id),
        club_name:  btn.dataset.club,
        country_id: Number(btn.dataset.country),
        room_name:  btn.dataset.room,
        description: btn.dataset.desc,
        email:      btn.dataset.email,
        whatsapp:   btn.dataset.whatsapp,
      }),
    });

    const data = await res.json() as { error?: string };

    if (!res.ok || data.error) {
      feedback.textContent = '❌ Error: ' + (data.error ?? 'Intenta nuevamente.');
      feedback.style.color = '#ff5252';
      allBtns.forEach(b => b.disabled = false);
      return;
    }

    feedback.textContent = '✅ Club creado y aprobado correctamente.';
    feedback.style.color = '#00e676';
    setTimeout(() => window.location.reload(), 1200);

  } catch {
    feedback.textContent = '❌ Error de conexión.';
    feedback.style.color = '#ff5252';
    allBtns.forEach(b => b.disabled = false);
  }
}

async function rejectRequest(btn: HTMLElement) {
  if (!confirm('¿Rechazar esta solicitud?')) return;

  const id       = btn.dataset.id!;
  const feedback = document.getElementById(`feedback-${id}`)!;
  const allBtns  = document.querySelectorAll<HTMLButtonElement>(`#req-${id} button`);

  allBtns.forEach(b => b.disabled = true);
  feedback.textContent = 'Rechazando...';
  feedback.style.color = 'rgba(255,255,255,0.4)';

  try {
    const res  = await fetch('/api/admin/solicitudes', {
      method:  'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ id: Number(id) }),
    });

    const data = await res.json() as { error?: string };

    if (!res.ok || data.error) {
      feedback.textContent = '❌ Error: ' + (data.error ?? 'Intenta nuevamente.');
      feedback.style.color = '#ff5252';
      allBtns.forEach(b => b.disabled = false);
      return;
    }

    feedback.textContent = '✅ Solicitud rechazada.';
    feedback.style.color = '#ffd740';
    setTimeout(() => window.location.reload(), 1000);

  } catch {
    feedback.textContent = '❌ Error de conexión.';
    feedback.style.color = '#ff5252';
    allBtns.forEach(b => b.disabled = false);
  }
}

(window as any).approveRequest = approveRequest;
(window as any).rejectRequest  = rejectRequest;
</script>