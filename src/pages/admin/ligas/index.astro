---
// src/pages/admin/ligas/index.astro
import AdminLayout from '@layouts/AdminLayout.astro';
import { createServerClient } from '@lib/supabase/server';

const supabase = createServerClient();

const { data: leagues } = await supabase
  .from('leagues')
  .select('*, clubs ( name, slug )')
  .order('name');

const activeCount   = leagues?.filter(l => l.is_active).length  ?? 0;
const inactiveCount = leagues?.filter(l => !l.is_active).length ?? 0;
---

<AdminLayout title="Ligas">

  <div class="page-header">
    <div>
      <p class="page-meta">
        <span class="meta-badge meta-active">{activeCount} activas</span>
        <span class="meta-badge meta-inactive">{inactiveCount} inactivas</span>
      </p>
    </div>
    <a href="/admin/ligas/nueva" class="btn btn-primary">+ Nueva Liga</a>
  </div>

  <div class="glass-card table-card">
    {leagues && leagues.length > 0 && (
      <table class="poker-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Liga</th>
            <th>Club</th>
            <th>Temporada</th>
            <th>Slug</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {leagues.map(league => {
            const club = league.clubs as { name: string; slug: string } | null;
            return (
              <tr id={`row-${league.id}`}>
                <td class="text-mono text-secondary">{league.id}</td>
                <td>
                  <div class="league-name-cell">
                    <div class="league-avatar">🏆</div>
                    <div>
                      <div class="league-name">{league.name}</div>
                      {league.description && (
                        <div class="club-desc">{league.description.slice(0, 50)}{league.description.length > 50 ? '…' : ''}</div>
                      )}
                    </div>
                  </div>
                </td>
                <td>
                  {club
                    ? <a href={`/admin/clubes`} class="table-link">{club.name}</a>
                    : <span class="text-muted">—</span>
                  }
                </td>
                <td class="text-secondary text-mono" style="font-size:0.8rem;">
                  {league.season_start && league.season_end
                    ? `${league.season_start} → ${league.season_end}`
                    : league.season_start
                      ? `Desde ${league.season_start}`
                      : <span class="text-muted">Sin fechas</span>
                  }
                </td>
                <td><code class="slug-code">{league.slug}</code></td>
                <td>
                  <span class={`status-badge ${league.is_active ? 'status-verified' : 'status-inactive'}`}>
                    {league.is_active ? '✓ Activa' : '✗ Inactiva'}
                  </span>
                </td>
                <td>
                  <div class="action-btns">
                    <a href={`/admin/ligas/${league.id}`} class="action-btn action-btn--edit" aria-label={`Editar ${league.name}`}>✏️</a>
                    <button
                      class={`action-btn ${league.is_active ? 'action-btn--warning' : 'action-btn--success'}`}
                      data-id={league.id}
                      data-active={String(league.is_active)}
                      onclick="toggleLeague(this)"
                    >{league.is_active ? '⏸' : '▶'}</button>
                    <button
                      class="action-btn action-btn--danger"
                      data-id={league.id}
                      data-name={league.name}
                      onclick="deleteLeague(this)"
                    >🗑</button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
    {(!leagues || leagues.length === 0) && (
      <div class="empty-state" style="padding:3rem;">
        <p style="font-size:2rem;margin:0;">🏆</p>
        <p>No hay ligas creadas aún.</p>
        <a href="/admin/ligas/nueva" class="btn btn-primary" style="margin-top:0.75rem;">Crear primera liga</a>
      </div>
    )}
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>

</AdminLayout>

<style is:global>
.league-name-cell {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.league-avatar {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, #ffd740, #f5af19);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  flex-shrink: 0;
}

.league-name {
  font-weight: 500;
  color: #e4e4ef;
  font-size: 0.9rem;
}
</style>

<script>
async function toggleLeague(btn: HTMLElement) {
  const id       = Number(btn.dataset.id);
  const isActive = btn.dataset.active === 'true';
  const newState = !isActive;

  (btn as HTMLButtonElement).disabled = true;

  try {
    const res  = await fetch('/api/admin/ligas', {
      method:  'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ id, is_active: newState }),
    });
    const data = await res.json() as { error?: string };

    if (!res.ok || data.error) {
      showToast(data.error ?? 'Error al actualizar.', 'error');
      return;
    }

    const row   = document.getElementById(`row-${id}`);
    const badge = row?.querySelector('.status-badge') as HTMLElement;

    btn.dataset.active = String(newState);
    btn.textContent    = newState ? '⏸' : '▶';
    btn.className      = `action-btn ${newState ? 'action-btn--warning' : 'action-btn--success'}`;
    if (badge) {
      badge.textContent = newState ? '✓ Activa' : '✗ Inactiva';
      badge.className   = `status-badge ${newState ? 'status-verified' : 'status-inactive'}`;
    }

    showToast(`Liga ${newState ? 'activada' : 'desactivada'}.`, 'success');
  } finally {
    (btn as HTMLButtonElement).disabled = false;
  }
}

async function deleteLeague(btn: HTMLElement) {
  const id   = Number(btn.dataset.id);
  const name = btn.dataset.name ?? 'esta liga';

  if (!confirm(`¿Eliminar "${name}"? Esta acción no se puede deshacer.`)) return;

  (btn as HTMLButtonElement).disabled = true;

  try {
    const res  = await fetch('/api/admin/ligas', {
      method:  'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ id }),
    });
    const data = await res.json() as { error?: string };

    if (!res.ok || data.error) {
      showToast(data.error ?? 'Error al eliminar.', 'error');
      (btn as HTMLButtonElement).disabled = false;
      return;
    }

    document.getElementById(`row-${id}`)?.remove();
    showToast(`Liga "${name}" eliminada.`, 'success');
  } catch {
    showToast('Error de conexión.', 'error');
    (btn as HTMLButtonElement).disabled = false;
  }
}

function showToast(msg: string, type: 'success' | 'error') {
  const toast = document.getElementById('toast')!;
  toast.textContent = msg;
  toast.className   = `toast toast--${type} is-visible`;
  setTimeout(() => toast.classList.remove('is-visible'), 3000);
}

(window as unknown as Record<string, unknown>).toggleLeague = toggleLeague;
(window as unknown as Record<string, unknown>).deleteLeague = deleteLeague;
</script>